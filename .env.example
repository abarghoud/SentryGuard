# =============================================================================
# SentryGuard - Docker Compose Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values before running docker-compose.

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=sentryguard
POSTGRES_PASSWORD=your_database_password_here
POSTGRES_DB=sentryguard

# -----------------------------------------------------------------------------
# Kafka
# -----------------------------------------------------------------------------
KAFKA_TOPIC=FleetTelemetry_V

# -----------------------------------------------------------------------------
# Fleet Telemetry
# -----------------------------------------------------------------------------
# All values must be base64-encoded: cat <file> | base64 -w 0
# The port below MUST match the port defined in your fleet-telemetry config JSON.
# See: https://github.com/teslamotors/fleet-telemetry
FLEET_TELEMETRY_PORT=4443
FLEET_TELEMETRY_CONFIG_B64=
FLEET_TELEMETRY_SERVER_CERT_B64=
FLEET_TELEMETRY_SERVER_KEY_B64=
# Optional: CA file for test vehicles
FLEET_TELEMETRY_CA_FILE_B64=

# -----------------------------------------------------------------------------
# Vehicle Command Proxy
# -----------------------------------------------------------------------------
# All values must be base64-encoded: cat <file> | base64 -w 0
VEHICLE_COMMAND_TLS_KEY_B64=
VEHICLE_COMMAND_TLS_CERT_B64=
VEHICLE_COMMAND_PRIVATE_KEY_B64=
VEHICLE_COMMAND_PORT=4444
VEHICLE_COMMAND_VERBOSE=false