{
  "cli": {
    "version": ">= 18.1.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "corepack": true,
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "corepack": true,
      "autoIncrement": true,
      "environment": "preview",
      "android": {
        "distribution": "internal",
        "buildType": "app-bundle"
      },
      "ios": {
        "distribution": "store"
      }
    },
    "preview-apk": {
      "extends": "preview",
      "android": {
        "distribution": "internal",
        "buildType": "apk"
      }
    },
    "production-preview": {
      "extends": "preview",
      "environment": "production"
    },
    "production": {
      "corepack": true,
      "autoIncrement": true,
      "environment": "production"
    }
  },
  "submit": {
    "preview": {
      "android": {
        "track": "internal"
      },
      "ios": {
        "ascAppId": "6779729590"
      }
    },
    "production-preview": {
      "android": {
        "track": "internal"
      },
      "ios": {
        "ascAppId": "6779729590"
      }
    },
    "production": {
      "android": {
        "track": "production"
      },
      "ios": {
        "ascAppId": "6779729590"
      }
    }
  }
}
