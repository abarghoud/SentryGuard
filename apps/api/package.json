{
  "name": "@tesla-guard/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "typeorm": "ts-node --project tsconfig.typeorm.json -r tsconfig-paths/register ./../../node_modules/typeorm/cli.js",
    "migration:generate": "npm run typeorm -- migration:generate src/migrations -d src/config/database.config.ts",
    "migration:run": "npm run typeorm -- migration:run -d src/config/database.config.ts",
    "migration:revert": "npm run typeorm -- migration:revert -d src/config/database.config.ts",
    "migration:show": "npm run typeorm -- migration:show -d src/config/database.config.ts"
  },
  "devDependencies": {
    "ts-node": "^10.9.2"
  }
}
