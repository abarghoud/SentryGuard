# ============================================================
# REQUIRED — Must be set before running SentryGuard
# ============================================================

# Database
DATABASE_USER=sentryguard
DATABASE_PASSWORD=              # REQUIRED — generate with: openssl rand -base64 24
DATABASE_NAME=sentryguard

# Security (generate each with: openssl rand -base64 32)
ENCRYPTION_KEY=                 # REQUIRED — min 32 characters
JWT_SECRET=                     # REQUIRED — min 32 characters
JWT_OAUTH_STATE_SECRET=         # REQUIRED — min 32 characters

# Telegram
TELEGRAM_BOT_TOKEN=             # REQUIRED — from @BotFather on Telegram
TELEGRAM_MODE=webhook
TELEGRAM_WEBHOOK_BASE=          # REQUIRED — e.g. https://api.yourdomain.com
TELEGRAM_WEBHOOK_SECRET_PATH=    # REQUIRED — min 16 chars, e.g. openssl rand -hex 16
TELEGRAM_WEBHOOK_SECRET_TOKEN=   # REQUIRED — min 24 chars, e.g. openssl rand -hex 24

# Tesla OAuth
TESLA_CLIENT_ID=                # REQUIRED — from developer.tesla.com
TESLA_CLIENT_SECRET=            # REQUIRED — from developer.tesla.com
TESLA_AUDIENCE=https://fleet-api.prd.eu.vn.cloud.tesla.com
TESLA_REDIRECT_URI=             # REQUIRED — e.g. https://api.yourdomain.com/callback/auth

# Fleet Telemetry
TESLA_FLEET_TELEMETRY_SERVER_HOSTNAME=  # REQUIRED — e.g. fleet-telemetry.yourdomain.com (no https://, no trailing /)
TESLA_FLEET_TELEMETRY_SERVER_PORT=11111

# Fleet Telemetry CA certificate (base64 of ca.crt — output from certificate generation steps)
LETS_ENCRYPT_CERTIFICATE=       # REQUIRED — base64 of ca.crt

# Tesla public key (base64 of public-key.pem — output from certificate generation steps)
TESLA_PUBLIC_KEY_BASE64=        # REQUIRED — base64 of public-key.pem

# Webapp URL (for CORS and redirects)
WEBAPP_URL=                     # REQUIRED — e.g. https://yourdomain.com

# CORS — additional allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=           # e.g. https://yourdomain.com,https://api.yourdomain.com

# Webapp runtime config (served via /api/runtime-config)
NEXT_PUBLIC_API_URL=             # REQUIRED — e.g. https://api.yourdomain.com

# ============================================================
# OPTIONAL — Has defaults, override if needed
# ============================================================

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_SSL=false
DATABASE_LOGGING=false
DATABASE_RUN_MIGRATIONS=true

# JWT
JWT_EXPIRATION=1d

# Tesla Telemetry intervals (seconds)
SENTRY_MODE_INTERVAL_SECONDS=30
BREAK_IN_MONITORING_INTERVAL_SECONDS=30

# Kafka (for self-hosted: kafka:29092 — leave defaults for docker-compose)
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=FleetTelemetry_V

# Host ports (for docker-compose mapping)
API_PORT=3021
WEBAPP_PORT=3020
FLEET_TELEMETRY_PORT=11111

# Logging
LOG_LEVEL=info
NODE_ENV=production

# Tesla Vehicle Command
TESLA_KEY_NAME=sentryguard