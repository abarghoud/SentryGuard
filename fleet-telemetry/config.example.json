{
  "host": "0.0.0.0",
  "port": 4443,
  "log_level": "info",
  "json_log_enable": true,
  "namespace": "FleetTelemetry",
  "reliable_ack": false,
  "monitoring": {
    "prometheus_metrics_port": 9090,
    "profiler_port": 4269,
    "profiling_path": "/tmp/trace.out"
  },
  "rate_limit": {
    "enabled": true,
    "message_interval_time": 30,
    "message_limit": 1000
  },
  "records": {
    "alerts": ["logger"],
    "errors": ["logger"],
    "V": ["kafka"],
    "connectivity": ["logger"]
  },
  "kafka": {
    "bootstrap.servers": "kafka:29092",
    "queue.buffering.max.messages": 1000000
  },
  "tls": {
    "server_cert": "/etc/fleet-telemetry/certs/fullchain.pem",
    "server_key": "/etc/fleet-telemetry/certs/privkey.pem"
  }
}
