{
  "host": "0.0.0.0",
  "port": 443,
  "log_level": "info",
  "json_log_enable": true,
  "namespace": "FleetTelemetry",
  "reliable_ack": true,
  "transmit_decoded_records": true,
  "monitoring": {
    "prometheus_metrics_port": 9090
  },
  "records": {
    "alerts": [
      "logger"
    ],
    "errors": [
      "logger"
    ],
    "V": [
      "kafka"
    ],
    "connectivity": [
      "logger"
    ]
  },
  "kafka": {
    "bootstrap.servers": "kafka:29092"
  },
  "tls": {
    "server_cert": "/etc/fleet-telemetry/certs/tls.crt",
    "server_key": "/etc/fleet-telemetry/certs/tls.key"
  }
}